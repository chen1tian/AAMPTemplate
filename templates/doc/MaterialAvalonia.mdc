## 2. 按钮 Button

### 2.1 普通按钮（默认填充样式）
```xml
<!-- 默认 Mid 色 -->
<Button Content="确认" />

<!-- 颜色变体 -->
<Button Classes="light" Content="Light" />
<Button Classes="dark" Content="Dark" />
<Button Classes="accent" Content="强调色" />

<!-- 自定义圆角 -->
<Button Content="圆角按钮" CornerRadius="16" />
```

### 2.2 描边按钮
```xml
<Button Theme="{StaticResource MaterialOutlineButton}" Content="取消" />
<Button Theme="{StaticResource MaterialOutlineButton}" Classes="accent" Content="强调" />
```

### 2.3 扁平按钮（用于工具栏/卡片内）
```xml
<Button Theme="{StaticResource MaterialFlatButton}" Content="操作" />
<Button Theme="{StaticResource MaterialFlatButton}" Classes="primary" Content="主色" />
<Button Theme="{StaticResource MaterialFlatButton}" Classes="accent" Content="强调" />
```

### 2.4 浮动按钮 FAB
```xml
<!-- 需引用 xmlns:material="using:Material.Styles.Controls" -->
<material:FloatingButton Classes="Accent">
    <material:FloatingButton.Content>
        <Template>
            <icons:MaterialIcon Kind="Plus" Width="24" Height="24" />
        </Template>
    </material:FloatingButton.Content>
</material:FloatingButton>

<!-- 扩展型（带文字） -->
<material:FloatingButton IsExtended="True" Classes="Accent" />

<!-- 尺寸：Mini（小）、默认（普通） -->
<material:FloatingButton Classes="Accent Mini" />
```

### 2.5 下拉按钮
```xml
<DropDownButton Theme="{StaticResource MaterialDropDownButton}" Content="更多">
    <DropDownButton.Flyout>
        <MenuFlyout Placement="BottomEdgeAlignedRight">
            <MenuItem Header="选项1" />
            <MenuItem Header="选项2" />
        </MenuFlyout>
    </DropDownButton.Flyout>
</DropDownButton>

<!-- 描边样式 -->
<DropDownButton Theme="{StaticResource MaterialOutlineDropDownButton}" Content="更多" ... />
```

### 2.6 超链接按钮
```xml
<HyperlinkButton Theme="{StaticResource MaterialHyperlinkButton}"
                 Content="点击跳转"
                 Command="{Binding OpenLinkCommand}" />
```

