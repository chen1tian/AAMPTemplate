## 3. 输入框 TextBox / Fields

### 3.1 经典样式（默认）
```xml
<!-- 浮动标签 -->
<TextBox UseFloatingPlaceholder="True"
         assists:TextFieldAssist.Label="用户名"
         PlaceholderText="请输入用户名" />

<!-- 无浮动标签 -->
<TextBox UseFloatingPlaceholder="False" PlaceholderText="搜索..." />

<!-- 密码框（带显示按钮） -->
<TextBox UseFloatingPlaceholder="True"
         Classes="revealPasswordButton"
         assists:TextFieldAssist.Label="密码"
         PasswordChar="*" />

<!-- 带清除按钮 -->
<TextBox UseFloatingPlaceholder="True"
         Classes="clearButton"
         assists:TextFieldAssist.Label="搜索" />

<!-- 禁用 -->
<TextBox UseFloatingPlaceholder="True"
         IsEnabled="False"
         assists:TextFieldAssist.Label="只读字段"
         Text="不可编辑" />

<!-- 多行 -->
<TextBox AcceptsReturn="True" MaxHeight="100" TextWrapping="Wrap"
         UseFloatingPlaceholder="True"
         assists:TextFieldAssist.Label="备注" />
```

### 3.2 填充样式 FilledTextBox
```xml
<TextBox Theme="{StaticResource FilledTextBox}"
         UseFloatingPlaceholder="True"
         Classes="filled"
         assists:TextFieldAssist.Label="填充样式" />

<!-- 紧凑版 -->
<TextBox Theme="{StaticResource FilledTextBox}"
         Classes="filled dense"
         UseFloatingPlaceholder="True"
         assists:TextFieldAssist.Label="紧凑输入框" />
```

### 3.3 描边样式 OutlineTextBox
```xml
<TextBox Theme="{StaticResource OutlineTextBox}"
         UseFloatingPlaceholder="True"
         Classes="outline"
         assists:TextFieldAssist.Label="描边样式" />

<!-- 描边+密码 -->
<TextBox Theme="{StaticResource OutlineTextBox}"
         Classes="outline revealPasswordButton"
         UseFloatingPlaceholder="True"
         assists:TextFieldAssist.Label="密码"
         PasswordChar="*" />
```

### 3.4 Solo 样式（嵌入卡片/顶栏搜索框）
```xml
<material:Card Padding="0">
    <TextBox Classes="solo" Theme="{StaticResource SoloTextBox}"
             PlaceholderText="搜索...">
        <TextBox.InnerRightContent>
            <Button Classes="Flat" Padding="4" Width="{Binding $self.Bounds.Height}"
                    Content="{icons:MaterialIconExt Search, IconSize=24}" />
        </TextBox.InnerRightContent>
    </TextBox>
</material:Card>
```

### 3.5 数字输入框
```xml
<NumericUpDown assists:TextFieldAssist.Label="数量"
               assists:TextFieldAssist.Hints="请输入正整数"
               PlaceholderText="0" />

<!-- 描边数字框 -->
<NumericUpDown Theme="{StaticResource OutlineNumericUpDown}" />
```

