## 9. TabControl 标签页

```xml
<!-- 标准标签页 -->
<TabControl>
    <TabItem Header="标签1">
        <TextBlock Text="内容1" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </TabItem>
    <TabItem Header="标签2">
        <TextBlock Text="内容2" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </TabItem>
</TabControl>

<!-- 可滚动标签页（标签过多时） -->
<TabControl Theme="{StaticResource ScrollableTabControl}" AutoScrollToSelectedItem="True">
    <TabItem Header="标签1"><TextBlock Text="内容1" /></TabItem>
    <TabItem Header="标签2"><TextBlock Text="内容2" /></TabItem>
</TabControl>

<!-- 带徽章的标签页 -->
<TabItem>
    <TabItem.Header>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <material:Badged BadgeContent="14">
                <icons:MaterialIcon Kind="MessageGroup" />
            </material:Badged>
            <TextBlock VerticalAlignment="Center" Text="消息" />
        </StackPanel>
    </TabItem.Header>
</TabItem>
```

