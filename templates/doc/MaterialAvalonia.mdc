## 6. NavigationDrawer 导航抽屉

```xml
<material:NavigationDrawer Name="LeftDrawer"
                            LeftDrawerOpened="{Binding NavDrawerSwitch, Mode=TwoWay}"
                            LeftDrawerWidth="200">
    <material:NavigationDrawer.LeftDrawerContent>
        <ListBox ItemsSource="{Binding MenuItems}"
                 SelectedItem="{Binding SelectedItem}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4">
                        <icons:MaterialIcon Data="{Binding Icon}" Width="22" Height="22" />
                        <TextBlock Text="{Binding Title}" FontSize="15" VerticalAlignment="Center" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerTheme>
                <ControlTheme TargetType="ListBoxItem"
                              BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="Padding" Value="6,10" />
                    <Setter Property="Margin" Value="8,2" />
                    <Setter Property="CornerRadius" Value="8" />
                </ControlTheme>
            </ListBox.ItemContainerTheme>
        </ListBox>
    </material:NavigationDrawer.LeftDrawerContent>

    <!-- 主内容区 -->
    <ContentControl Content="{Binding CurrentPage}" />
</material:NavigationDrawer>
```

