## 14. Badge / Badged 徽章

```xml
<!-- 独立徽章 -->
<material:Badge Content="1" ColorMode="Accent" />
<material:Badge Content="999+" ColorMode="Inverted" />
<material:Badge DisplayContent="False" />  <!-- 仅圆点 -->

<!-- 附加在控件上 -->
<material:Badged BadgeContent="5">
    <icons:MaterialIcon Kind="Bell" Width="24" Height="24" />
</material:Badged>

<!-- 仅圆点（无数字） -->
<material:Badged BadgeDisplayContent="False">
    <Button Content="消息" />
</material:Badged>

<!-- 自定义颜色 -->
<material:Badged BadgeContent="NEW!"
                 BadgeBackground="{DynamicResource MaterialSecondaryLightBrush}"
                 BadgeForeground="{DynamicResource MaterialSecondaryLightForegroundBrush}">
    <Button Content="探索" />
</material:Badged>

<!-- 控制位置 -->
<material:Badged BadgeContent="4" BadgePlacement="Right">
    <TextBlock Text="消息" />
</material:Badged>
```

