## 7. 选择控件

### 7.1 ToggleSwitch
```xml
<ToggleSwitch Content="启用功能" />
<ToggleSwitch Content="已启用" IsChecked="True" />
<ToggleSwitch Content="强调色" IsChecked="True" Classes="accent" />
<!-- 标签在左侧 -->
<ToggleSwitch Classes="LeftHeader" Content="左侧标签" />
```

### 7.2 CheckBox
```xml
<CheckBox Content="普通复选框" />
<CheckBox Content="已选中" IsChecked="True" />
<CheckBox Content="禁用" IsEnabled="False" />
<CheckBox Content="强调色" Classes="accent" IsChecked="True" />
<!-- 不确定状态 -->
<CheckBox Content="不确定" IsChecked="{x:Null}" />
```

### 7.3 RadioButton
```xml
<RadioButton GroupName="g1" Content="选项A" />
<RadioButton GroupName="g1" Content="选项B" IsChecked="True" />
<RadioButton GroupName="g1" Content="强调色" Classes="accent" />

<!-- 按钮形式（放在 Card 内） -->
<material:Card Padding="0" InsideClipping="True">
    <material:Card.Styles>
        <Style Selector="RadioButton">
            <Setter Property="Theme" Value="{StaticResource MaterialButtonlikeRadioButton}" />
        </Style>
    </material:Card.Styles>
    <StackPanel Orientation="Horizontal">
        <RadioButton GroupName="align" Content="{icons:MaterialIconExt Kind=FormatAlignLeft}" />
        <RadioButton GroupName="align" Content="{icons:MaterialIconExt Kind=FormatAlignCenter}" IsChecked="True" />
        <RadioButton GroupName="align" Content="{icons:MaterialIconExt Kind=FormatAlignRight}" />
    </StackPanel>
</material:Card>
```

### 7.4 ToggleButton
```xml
<ToggleButton>默认</ToggleButton>
<ToggleButton Classes="primary">主色</ToggleButton>
<ToggleButton Classes="accent">强调色</ToggleButton>
<ToggleButton Theme="{StaticResource MaterialOutlineToggleButton}">描边</ToggleButton>
<ToggleButton Theme="{StaticResource MaterialFlatToggleButton}">扁平</ToggleButton>
<!-- 图标切换按钮 -->
<ToggleButton Theme="{StaticResource MaterialIconToggleButton}">
    <icons:MaterialIcon Kind="Heart" />
</ToggleButton>
```

