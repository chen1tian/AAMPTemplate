## 11. Expander 折叠面板

```xml
<!-- 向下展开（默认） -->
<Expander Header="点击展开">
    <TextBlock TextWrapping="Wrap" Text="内容..." />
</Expander>

<!-- 向上展开 -->
<Expander ExpandDirection="Up" Header="向上展开">
    <TextBlock Text="内容..." />
</Expander>

<!-- 向左/右展开 -->
<Expander ExpandDirection="Left" Header="←" />
<Expander ExpandDirection="Right" Header="→" />

<!-- 自定义 Header -->
<Expander>
    <Expander.Header>
        <StackPanel Spacing="4">
            <TextBlock Text="主标题" FontSize="16" FontWeight="Bold" />
            <TextBlock Text="副标题说明" FontSize="13" />
        </StackPanel>
    </Expander.Header>
    <TextBlock Text="展开内容..." />
</Expander>
```

