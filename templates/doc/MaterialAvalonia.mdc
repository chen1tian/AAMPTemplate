## 4. Card 卡片

```xml
<!-- 基础卡片 -->
<material:Card>
    <StackPanel Margin="0,4">
        <TextBlock Classes="Headline6" Text="卡片标题" />
        <TextBlock Classes="Body2" Text="副标题" />
    </StackPanel>
</material:Card>

<!-- 固定宽度 -->
<material:Card Width="240" VerticalAlignment="Top">
    <StackPanel Margin="0,4">
        <TextBlock Classes="Headline6" Text="标题" />
        <TextBlock TextWrapping="Wrap" Text="内容文字..." />
    </StackPanel>
</material:Card>

<!-- 带底部操作按钮 -->
<material:Card Width="240" Padding="4">
    <StackPanel>
        <StackPanel Margin="8">
            <TextBlock Classes="Headline6" Text="标题" />
            <TextBlock TextWrapping="Wrap" Text="内容..." />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Button Theme="{StaticResource MaterialFlatButton}" Content="操作1" />
            <Button Theme="{StaticResource MaterialFlatButton}" Content="操作2" />
        </StackPanel>
    </StackPanel>
</material:Card>
```

