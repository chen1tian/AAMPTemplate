## 8. ComboBox 下拉选择

```xml
<!-- 默认样式 -->
<ComboBox PlaceholderText="请选择">
    <ComboBoxItem>选项1</ComboBoxItem>
    <ComboBoxItem>选项2</ComboBoxItem>
</ComboBox>

<!-- 填充样式 -->
<ComboBox Theme="{StaticResource MaterialFilledComboBox}">
    <ComboBoxItem>选项1</ComboBoxItem>
</ComboBox>

<!-- 描边样式（带浮动标签） -->
<ComboBox Theme="{StaticResource MaterialOutlineComboBox}"
          assists:ComboBoxAssist.Label="选择类型">
    <ComboBoxItem>选项1</ComboBoxItem>
</ComboBox>

<!-- 紧凑描边 -->
<ComboBox Theme="{StaticResource MaterialOutlineComboBox}"
          Classes="dense"
          assists:ComboBoxAssist.Label="紧凑选择">
    <ComboBoxItem>选项1</ComboBoxItem>
</ComboBox>
```

