## 10. ProgressBar 进度条

```xml
<!-- 线性进度条 -->
<ProgressBar Value="30" />
<ProgressBar Value="{Binding Progress}" />
<ProgressBar IsIndeterminate="True" />
<ProgressBar Value="{Binding Progress}" ShowProgressText="True" />
<ProgressBar Orientation="Vertical" Value="60" />

<!-- 圆形进度条 -->
<ProgressBar Classes="circular" Value="60" />
<ProgressBar Classes="circular" IsIndeterminate="True" />
<material:Card CornerRadius="24" Padding="4" HorizontalAlignment="Center" VerticalAlignment="Center">
    <ProgressBar Classes="circular" Width="80" Height="80" Value="{Binding Progress}" />
</material:Card>
```

