<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AAMPTpl.ViewModels"
			 xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AAMPTpl.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <dialogHostAvalonia:DialogHost Identifier="MainDialogHost" DisableOpeningAnimation="True">
    <SplitView IsPaneOpen="{Binding NavDrawerSwitch, Mode=TwoWay}"
               DisplayMode="CompactInline"
               OpenPaneLength="150"
               CompactPaneLength="56"
               PaneBackground="{DynamicResource MaterialBackgroundBrush}">
      <SplitView.Pane>
        <DockPanel LastChildFill="True">
          <Border DockPanel.Dock="Top" Padding="16,18,16,12">
            <TextBlock Text="AAMPTpl"
                       Classes="Headline6"
                       IsVisible="{Binding IsMenuTextVisible}"
                       VerticalAlignment="Center" />
          </Border>

          <Border DockPanel.Dock="Bottom"
                  Height="1"
                  Background="{DynamicResource MaterialDividerBrush}" />

          <ScrollViewer>
            <ListBox ItemsSource="{Binding MenuItems}"
                     SelectedItem="{Binding SelectedMenuItem}"
                     Background="Transparent"
                     Margin="4,8">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:NavMenuItem">
                  <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,4">
                    <PathIcon x:CompileBindings="False"
                              Data="{Binding Icon}"
                              Width="22"
                              Height="22"
                              VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Title}"
                               FontSize="15"
                               IsVisible="{Binding $parent[UserControl].DataContext.IsMenuTextVisible}"
                               VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>

              <ListBox.ItemContainerTheme>
                <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                  <Setter Property="Padding" Value="6,10" />
                  <Setter Property="Margin" Value="8,2" />
                  <Setter Property="CornerRadius" Value="8" />
                </ControlTheme>
              </ListBox.ItemContainerTheme>
            </ListBox>
          </ScrollViewer>
        </DockPanel>
      </SplitView.Pane>

      <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Height="56"
                Padding="16,0"
                Background="{DynamicResource MaterialPrimaryMidBrush}">
          <Grid ColumnDefinitions="32,16,*,Auto">
            <ToggleButton Width="32"
                          Height="32"
                          Padding="4"
                          IsChecked="{Binding NavDrawerSwitch, Mode=TwoWay}"
                          VerticalAlignment="Center">
              <PathIcon x:CompileBindings="False"
                        Data="{Binding ToggleMenuIcon}"
                        Width="22"
                        Height="22" />
            </ToggleButton>

            <TextBlock Grid.Column="2"
                       Classes="Headline6"
                       Text="AAMPTpl"
                       VerticalAlignment="Center" />

            <Menu Grid.Column="3"
                  Padding="0"
                  Margin="0"
                  VerticalAlignment="Center">
              <MenuItem Header="操作">
                <MenuItem Header="Action 1" />
                <MenuItem Header="Action 2" />
                <MenuItem Header="Action 3" />
              </MenuItem>
            </Menu>
          </Grid>
        </Border>

        <NavigationPage x:Name="MainNavigation"
                        IsBackButtonVisible="False"
                        IsGestureEnabled="False"
                        HasShadow="True" />
      </DockPanel>
    </SplitView>
	</dialogHostAvalonia:DialogHost>
</UserControl>
