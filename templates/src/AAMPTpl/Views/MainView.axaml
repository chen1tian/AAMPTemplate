<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AAMPTpl.ViewModels"
			 xmlns:controls="using:Material.Styles.Controls"
			 xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
			 xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AAMPTpl.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
    <vm:MainViewModel />
  </Design.DataContext>

  <dialogHostAvalonia:DialogHost Identifier="MainDialogHost">
		<controls:NavigationDrawer
		Name="LeftDrawer"
		LeftDrawerOpened="{Binding NavDrawerSwitch, Mode=TwoWay}"
		LeftDrawerWidth="150"
		>
			<!--左侧菜单-->
			<controls:NavigationDrawer.LeftDrawerContent>
				<ScrollViewer>
					<ListBox Grid.Row="0"
							 ItemsSource="{Binding MenuItems}"
							 SelectedItem="{Binding SelectedMenuItem}"
							 Background="Transparent"
							 Margin="4,8">
						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="vm:NavMenuItem">
								<StackPanel Orientation="Horizontal" Spacing="14" Margin="0,4">
									<PathIcon x:CompileBindings="False"
											  Data="{Binding Icon}"
											  Width="22" Height="22"
											  VerticalAlignment="Center" />
									<TextBlock Text="{Binding Title}"
											   FontSize="15"
											   x:CompileBindings="False"
											   IsVisible="{Binding $parent[UserControl].DataContext.IsMenuTextVisible}"
											   VerticalAlignment="Center" />
								</StackPanel>
							</DataTemplate>
						</ListBox.ItemTemplate>

						<ListBox.ItemContainerTheme>
							<ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
								<Setter Property="Padding" Value="6,10" />
								<Setter Property="Margin" Value="8,2" />
								<Setter Property="CornerRadius" Value="8" />
							</ControlTheme>
						</ListBox.ItemContainerTheme>
					</ListBox>
				</ScrollViewer>
			</controls:NavigationDrawer.LeftDrawerContent>

			<!--内容区-->
			<DockPanel LastChildFill="true">
				<!--顶部层-->
				<controls:ColorZone Name="PART_AppBarContainer" VerticalAlignment="Top" HorizontalAlignment="Stretch"
									DockPanel.Dock="Top"
									Height="56" Mode="PrimaryMid" ZIndex="1">
					<Grid Margin="16">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="24" />
							<ColumnDefinition Width="32" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="32" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<ToggleButton Name="NavDrawerSwitch"
									  Theme="{StaticResource MaterialFlatButton}"
									  Width="32" Height="32" Padding="4"
									  IsChecked="{Binding NavDrawerSwitch, Mode=TwoWay}">
							<icons:MaterialIcon Kind="Menu" Width="24" Height="24" />
						</ToggleButton>
						<!--标题-->
						<TextBlock Grid.Column="2" Classes="Headline6" Text="AAMPTp"
								   VerticalAlignment="Center" />

						<!--操作菜单-->
						<Menu Grid.Column="4" Height="32" Padding="0" Margin="0">
							<MenuItem Height="32" Width="32" Header="">
								<MenuItem Header="Action 1" />
								<MenuItem Header="Action 2" />
								<MenuItem Header="Action 3" />
							</MenuItem>
						</Menu>
					</Grid>
				</controls:ColorZone>
				<!--主要内容区-->
				<ContentControl
				Content="{Binding CurrentPage}"
				Margin="0" />
			</DockPanel>

		</controls:NavigationDrawer>
	</dialogHostAvalonia:DialogHost>
</UserControl>
