<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<LangVersion>latest</LangVersion>
		<AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
	</PropertyGroup>

	<ItemGroup>
		<AvaloniaResource Include="Assets\**" />
	</ItemGroup>

	<ItemGroup>
	  <None Remove="appsettings.json" />
	  <None Remove="Resources\Fonts\SourceHanSansSC-Medium.otf" />
	  <None Remove="Resources\Fonts\SourceHanSansSC-Normal.otf" />
	  <None Remove="Resources\Fonts\SourceHanSansSC-Regular.otf" />
	</ItemGroup>

	<ItemGroup>
	  <AvaloniaResource Include="appsettings.json">
	    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
	  </AvaloniaResource>
	  <AvaloniaResource Include="Resources\Fonts\SourceHanSansSC-Medium.otf" />
	  <AvaloniaResource Include="Resources\Fonts\SourceHanSansSC-Normal.otf" />
	  <AvaloniaResource Include="Resources\Fonts\SourceHanSansSC-Regular.otf" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Avalonia" />
		<PackageReference Include="Avalonia.Themes.Fluent" />
		<PackageReference Include="DialogHost.Avalonia" />
		<PackageReference Include="Material.Avalonia" />
		<PackageReference Include="Material.Icons.Avalonia" />
		<PackageReference Include="Avalonia.Fonts.Inter" />
		<!--Condition below is needed to remove AvaloniaUI.DiagnosticsSupport package from build output in Release configuration.-->
		<PackageReference Include="AvaloniaUI.DiagnosticsSupport">
			<IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
			<PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
		</PackageReference>
		<PackageReference Include="CommunityToolkit.Mvvm" />		
		<PackageReference Include="Serilog.Extensions.Hosting" />
		<PackageReference Include="Serilog.Extensions.Logging" />
		<PackageReference Include="Serilog.Sinks.Async" />
		<PackageReference Include="Serilog.Sinks.File" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Design" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\abp\AAMPTpl.Application.Contracts\AAMPTpl.Application.Contracts.csproj" />
		<ProjectReference Include="..\abp\AAMPTpl.Application\AAMPTpl.Application.csproj" />
		<ProjectReference Include="..\abp\AAMPTpl.Domain\AAMPTpl.Domain.csproj" />
		<ProjectReference Include="..\abp\AAMPTpl.EntityFramework.MySql\AAMPTpl.EntityFramework.MySql.csproj" />
		<ProjectReference Include="..\abp\AAMPTpl.EntityFramework.SqlServer\AAMPTpl.EntityFramework.SqlServer.csproj" />
		<ProjectReference Include="..\abp\AAMPTpl.EntityFramework\AAMPTpl.EntityFramework.csproj" />
	</ItemGroup>
</Project>
